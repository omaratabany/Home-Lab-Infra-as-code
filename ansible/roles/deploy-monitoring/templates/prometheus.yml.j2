# prometheus.yml
# Generated by Ansible. Do not edit manually.

global:
  scrape_interval:     15s
  evaluation_interval: 15s
  external_labels:
    site: homelab
    host: ms01

scrape_configs:

  - job_name: prometheus
    static_configs:
      - targets: ['localhost:9090']

  - job_name: node_exporter
    static_configs:
      - targets: ['{{ ansible_host }}:9100']
    relabel_configs:
      - source_labels: [__address__]
        target_label: instance
        regex: '([^:]+).*'
        replacement: 'ms01'

  - job_name: cadvisor
    static_configs:
      - targets: ['cadvisor:8080']

  - job_name: uptime_kuma
    static_configs:
      - targets: ['{{ ansible_host }}:3001']
