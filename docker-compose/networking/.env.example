# =============================================================================
# NETWORKING STACK — Environment Variables
# =============================================================================

TZ=Asia/Dubai
APPDATA=/mnt/user/appdata

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Generate a tunnel token at: https://one.dash.cloudflare.com/
# Zero Trust → Networks → Tunnels → Create tunnel → copy token
CF_TUNNEL_TOKEN=eyJ...your_tunnel_token_here

# Tunnel log level: debug | info | warn | error | fatal
TUNNEL_LOGLEVEL=info

# Prometheus metrics port (internal scraping only — not exposed externally)
TUNNEL_METRICS_PORT=46495

# ── Route map (document your public hostnames here) ──────────────────────────
# plex.yourdomain.com        → localhost:32400
# jellyfin.yourdomain.com    → localhost:8096
# sonarr.yourdomain.com      → localhost:8989
# radarr.yourdomain.com      → localhost:7878
# overseerr.yourdomain.com   → localhost:5055
# n8n.yourdomain.com         → localhost:5678
# Configure these in the Cloudflare Zero Trust dashboard, not here.
