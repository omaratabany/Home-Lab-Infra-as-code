# =============================================================================
# MAIL STACK — Environment Variables
# =============================================================================

TZ=Asia/Dubai
APPDATA=/mnt/user/appdata

# ── Mail domain ───────────────────────────────────────────────────────────────
MAIL_DOMAIN=yourdomain.com
MAIL_HOSTNAME=mail.yourdomain.com

# ── SSL ───────────────────────────────────────────────────────────────────────
# Options: letsencrypt | self-signed | manual
SSL_TYPE=letsencrypt

# ── DNS Records required ──────────────────────────────────────────────────────
# MX   yourdomain.com        → mail.yourdomain.com (priority 10)
# A    mail.yourdomain.com   → YOUR_SERVER_IP
# SPF  yourdomain.com        → "v=spf1 mx ~all"
# DMARC _dmarc.yourdomain.com → "v=DMARC1; p=quarantine; rua=mailto:postmaster@yourdomain.com"
