# =============================================================================
# MEDIA STACK — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Asia/Dubai

# ── User/Group IDs (match Unraid's nobody/users) ─────────────────────────────
PUID=99
PGID=100

# ── Host IP (used by Tdarr for node/server discovery) ────────────────────────
SERVER_IP=192.168.x.x

# ── Plex ─────────────────────────────────────────────────────────────────────
# Get a one-time claim token from: https://plex.tv/claim
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# ── Paths ─────────────────────────────────────────────────────────────────────
# Appdata (container configs)
APPDATA=/mnt/user/appdata

# Media library root
MEDIA_PATH=/mnt/user/media

# Shared downloads volume (SABnzbd + qBittorrent write here; *arr reads here)
DOWNLOADS_PATH=/mnt/user/downloads

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
